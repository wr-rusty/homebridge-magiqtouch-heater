{
  "name": "homebridge-magiqtouch-heater",
  "displayName": "MagIQTouch Heater",
  "version": "1.0.0",
  "description": "Homebridge plugin for the Seeley MagIQTouch ducted gas heater controller.",
  "author": "wr-rusty",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wr-rusty/homebridge-magiqtouch-heater.git"
  },
  "bugs": {
    "url": "https://github.com/wr-rusty/homebridge-magiqtouch-heater/issues"
  },
  "homepage": "https://github.com/wr-rusty/homebridge-magiqtouch-heater#readme",
  "engines": {
    "node": "^20 || ^22 || ^24",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "watch": "nodemon",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "harness": "node dist/cli/harness.js",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "magiqtouch",
    "seeley",
    "braemar",
    "heater",
    "homekit"
  ],
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.0",
    "homebridge": "^1.8.4",
    "nodemon": "^3.1.4",
    "rimraf": "^5.0.9",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
